# .claude and .mcp.json come from dotfiles-v2-test-data, created per-machine by its
# install.ps1/install.sh. Never track from this repo (would duplicate dotfiles content
# and bake in machine/OS-specific values):
#   .claude   = SYMLINK to the dotfiles config tree (OS-neutral).
#   .mcp.json = GENERATED from the dotfiles canonical .mcp.json, with an OS-correct npx
#               launcher (Windows: cmd /c npx; macOS/Linux: npx). Was previously a
#               committed symlink-blob with a hardcoded ../../ path; untracked 2026-05-29.
.claude/
.claude
.agents/
.agents
.mcp.json

# Per-folder Supabase CLI local state — never commit, all machine-specific
supabase/.temp/         # link state (project ref, temp creds)
supabase/.branches/     # `supabase db branches` local pointer
supabase/snippets/      # SQL snippets synced from dashboard (local cache)

# Supabase functions Deno cache (generated)
supabase/functions/**/.cache/

# Secrets — never commit
# (Previously had `!.env.example` exception, but the local .env.example was
#  found to contain LIVE secrets — convention violated, so the exception was
#  removed 2026-05-11. If you need a tracked template again, create a
#  .env.template with placeholder values only and add it as an exception here.)
.env
.env.*

# Node / npm
node_modules/
*.log
npm-debug.log*

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Editor noise (we DO track .vscode/settings.json for Deno setup; only personal preferences excluded)
*.swp
*.swo
*~
.idea/

# Claude Code sub-agent staging area (per .claude/rules/orchestration.md transfer pattern)
# Sub-agents stage to .tmp/agent-output/; orchestrator copies to canonical paths.
# Never commit raw staging output — committed copies live under .claude/work/...
.tmp/

# feature-workflow-hook + ai-cross-verify per-session artifacts.
# Don't commit — these are local-session state.
.claude/work/current-feature.json
.claude/work/feature-skip.json
.claude/work/ai-review-*.md
.claude/work/feature-archive/

# Playwright MCP per-conversation debug captures (console + page snapshots)
.playwright-mcp/

# Stray root-level npm lockfile (the real one lives in scheduler-app/)
/package-lock.json

.vercel
.env*
