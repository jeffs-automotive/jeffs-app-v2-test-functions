{
  "name": "scheduler-app",
  "version": "0.1.0",
  "description": "Customer-facing appointment scheduler for Jeff's Automotive — chat agent at appointments.jeffsautomotive.com. See ../docs and dotfiles-v2-test-data/.../.claude/memory/appointments_design.md for the architectural binding.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "echo '[scheduler-app] Reminder: run `npm install` at the repo root to wire husky pre-commit hooks.'"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/gateway": "^2.0.91",
    "@ai-sdk/openai": "^2.0.0",
    "@anthropic-ai/sdk": "^0.97.1",
    "@hookform/resolvers": "^3.0.0",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.0.0",
    "ai": "^5.0.0",
    "botid": "^1.5.11",
    "motion": "^12.38.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "resend": "^4.0.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.0.0",
    "@next/eslint-plugin-next": "^15.0.0",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.5.2",
    "msw": "^2.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
